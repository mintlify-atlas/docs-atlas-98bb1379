{
  "projectType": "cli-tool",
  "projectName": "Dufs",
  "projectDescription": "A distinctive utility file server written in Rust that supports static serving, file upload/download, searching, access control, WebDAV, and HTTPS.",
  "theme": "palm",
  "primaryColor": "#94cb04",
  "lightColor": "#545454",
  "darkColor": null,
